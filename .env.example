# =============================================================================
# NutriTrack — Environment Variables
# =============================================================================
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env
#
# Все переменные должны начинаться с EXPO_PUBLIC_ чтобы быть доступны
# в коде React Native через process.env.EXPO_PUBLIC_*
# =============================================================================

# -----------------------------------------------------------------------------
# FIREBASE
# Где взять:
#   1. Открой https://console.firebase.google.com
#   2. Создай новый проект (или открой существующий)
#   3. Перейди: Project Settings (шестерёнка) → General → Your apps
#   4. Нажми "</>" (Add web app) если приложения ещё нет → зарегистрируй
#   5. Firebase покажет firebaseConfig — скопируй значения отсюда:
#      apiKey            → EXPO_PUBLIC_FIREBASE_API_KEY
#      authDomain        → EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN
#      projectId         → EXPO_PUBLIC_FIREBASE_PROJECT_ID
#      storageBucket     → EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET
#      messagingSenderId → EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
#      appId             → EXPO_PUBLIC_FIREBASE_APP_ID
# -----------------------------------------------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456
